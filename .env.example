# Application
APP_NAME=AI Documentary Studio
APP_VERSION=0.1.0
DEBUG=False

# Backend Server
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# LLM Provider (mock | ollama | openai)
LLM_PROVIDER=mock

# Ollama (if using ollama provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_CONTEXT_WINDOW=4096

# YouTube (Phase 4)
YOUTUBE_API_KEY=your_api_key_here
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here

# Research
RESEARCH_MAX_SOURCES=50
RESEARCH_TIMEOUT_SECONDS=300

# Video Rendering
FFMPEG_PATH=/usr/bin/ffmpeg
MAX_VIDEO_LENGTH_MINUTES=30

# Logging
LOG_LEVEL=INFO

